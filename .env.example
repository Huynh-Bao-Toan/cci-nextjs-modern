#
# Base env example (shared defaults)
#
# Copy the relevant example file(s) to real env files:
# - Development (local):    .env.development.local (or .env.local)
# - Production (simulate):  .env.production.local
# - Test (UAT/BETA):        .env.test   (and/or .env.test.local)
#

# Public (bundled to the browser if used in client code)
NEXT_PUBLIC_APP_NAME="cci-nextjs-modern"
NEXT_PUBLIC_APP_ENV="development" # development | production | test
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_API_BASE_URL="http://localhost:3000/api"

# Server-only (never expose to client)
APP_SECRET="replace-me"
DATABASE_URL="postgres://user:pass@localhost:5432/db"

# Optional example
NEXT_PUBLIC_ANALYTICS_ID=""

