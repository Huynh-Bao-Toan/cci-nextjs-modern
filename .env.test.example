#
# Test environment example (UAT / BETA)
# Loaded when NODE_ENV=test
#
# Important:
# - `.env.local` is NOT loaded when NODE_ENV=test
# - Prefer committing `.env.test` only if it contains NO secrets
#

NEXT_PUBLIC_APP_ENV="test"
NEXT_PUBLIC_SITE_URL="https://beta.your-domain.com"
NEXT_PUBLIC_API_BASE_URL="https://beta.your-domain.com/api"
NEXT_PUBLIC_DUMMYJSON_BASE_URL="https://dummyjson.com"

# Server-only
APP_SECRET="replace-me"
DATABASE_URL="postgres://user:pass@uat-host:5432/cci_nextjs_modern_uat"

